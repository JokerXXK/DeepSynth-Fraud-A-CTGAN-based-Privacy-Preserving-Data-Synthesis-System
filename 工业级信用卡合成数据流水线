= SingleTableMetadata()\n","        self.metadata.detect_from_dataframe(self.real_data)\n","        self.metadata.update_column(column_name='Class', sdtype='categorical')\n","\n","        print(f\"数据就绪。真实样本量: {len(self.real_data)} (其中欺诈案例: {len(fraud)})\")\n","\n","    def train_synthesizer(self, epochs=30):\n","        print(f\"[2/6] 启动 CTGAN 模型训练 (迭代次数: {epochs})...\")\n","        start_time = time.time()\n","\n","        # 【关键】SDV 1.x的CTGANSynthesizer不需要table_name\n","        self.synthesizer = CTGANSynthesizer(\n","            metadata=self.metadata,\n","            epochs=epochs,\n","            verbose=True\n","        )\n","\n","        self.synthesizer.fit(self.real_data)\n","\n","        duration = time.time() - start_time\n","        print(f\"训练完成，耗时: {duration:.2f} 秒\")\n","\n","    def generate_data(self, count=3000):\n","        print(f\"[3/6] 正在采样生成 {count} 条合成交易数据...\")\n","        self.synthetic_data = self.synthesizer.sample(num_rows=count)\n","        return self.synthetic_data\n","\n","    def evaluate_statistical_fidelity(self):\n","        print(\"[4/6] 执行统计保真度诊断...\")\n","        quality_report = evaluate_quality(\n","            self.real_data,\n","            self.synthetic_data,\n","            self.metadata\n","        )\n","        score = quality_report.get_score()\n","        print(f\"-> 总体数据质量得分: {score:.2%}\")\n","        return quality_report\n","\n","    def visual_comparison(self):\n","        print(\"[5/6] 正在生成相关性热图对比...\")\n","        fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 6))\n","\n","        cols = ['V1', 'V2', 'V3', 'V4', 'V5', 'Amount', 'Class']\n","        available_cols = [c for c in cols if c in self.real_data.columns]\n","\n","        sns.heatmap(self.real_data[available_cols].corr(), annot=True, cmap='RdBu', fmt='.2f', ax=ax1)\n","        ax1.set_title(\"Real Data Correlation\")\n","\n","        sns.heatmap(self.synthetic_data[available_cols].corr(), annot=True, cmap='RdBu', fmt='.2f', ax=ax2)\n","        ax2.set_title(\"Synthetic Data Correlation\")\n","\n","        plt.tight_layout()\n","        plt.show()\n","\n","    def machine_learning_test(self):\n","        print(\"[6/6] 启动机器学习效能测试...\")\n","\n","        X_real = self.real_data.drop('Class', axis=1)\n","        y_real = self.real_data['Class']\n","        X_train_r, X_test_r, y_train_r, y_test_r = train_test_split(\n","            X_real, y_real, test_size=0.3, stratify=y_real, random_state=42\n","        )\n","\n","        X_syn = self.synthetic_data.drop('Class', axis=1)\n","        y_syn = self.synthetic_data['Class']\n","\n","        # 基准模型\n","        model_real = GradientBoostingClassifier(random_state=42)\n","        model_real.fit(X_train_r, y_train_r)\n","        base_auc = roc_auc_score(y_test_r, model_real.predict_proba(X_test_r)[:, 1])\n","\n","        # 合成模型\n","        model_syn = GradientBoostingClassifier(random_state=42)\n","        model_syn.fit(X_syn, y_syn)\n","        syn_auc = roc_auc_score(y_test_r, model_syn.predict_proba(X_test_r)[:, 1])\n","\n","        print(\"\\n\" + \"=\"*50)\n","        print(f\"基准 AUC: {base_auc:.4f}\")\n","        print(f\"合成 AUC: {syn_auc:.4f}\")\n","        print(f\"可用性比率: {(syn_auc/base_auc):.2%}\")\n","        print(\"=\"*50)\n","\n","# 执行\n","if __name__ == \"__main__\":\n","    URL = \"https://raw.githubusercontent.com/nsethi31/Kaggle-Data-Credit-Card-Fraud-Detection/master/creditcard.csv\"\n","\n","    pipeline = PrivateDataPipeline(URL)\n","    pipeline.load_and_preprocess()\n","    pipeline.train_synthesizer(epochs=200)\n","    pipeline.generate_data(3000)\n","    pipeline.evaluate_statistical_fidelity()\n","    pipeline.visual_comparison()\n","    pipeline.machine_learning_test()"],"outputs":[{"output_type":"stream","name":"stdout","text":["[1/6] 正在从安全镜像加载真实信用卡数据集...\n","正在检测数据元数据...\n","数据就绪。真实样本量: 5492 (其中欺诈案例: 492)\n","[2/6] 启动 CTGAN 模型训练 (迭代次数: 200)...\n"]},{"output_type":"stream","name":"stderr","text":["Gen. (-02.98) | Discrim. (+00.19): 100%|███████